<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Assignment 6 – Gantt Chart</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
  body {
    font-family: Segoe UI, Calibri, sans-serif;
    background: #f7f7f7;
    margin: 30px;
  }
  h1 {
    color: #005a9e;
  }
  #chart {
    margin-top: 30px;
    background: #fff;
    border: 1px solid #ccc;
    padding: 20px;
    overflow-x: auto;
  }
  .row {
    display: flex;
    align-items: center;
    margin: 6px 0;
  }
  .label {
    width: 200px;
    font-size: 0.9rem;
  }
  .bar {
    height: 20px;
    border-radius: 4px;
    position: relative;
  }
  .axis {
    display: flex;
    margin-left: 200px;
    margin-bottom: 10px;
    font-size: 0.8rem;
    color: #555;
  }
  .tick {
    width: 30px;
    text-align: center;
  }
</style>
</head>

<body>
<h1>Assignment 6 – Project Initiation Gantt Chart</h1>
<p>This chart is generated from the Assignment 6 task list.</p>

<div id="chart"></div>

<script>
const tasks = [
  { name: "Project Sponsor", start: 1, duration: 1, color: "#888" },
  { name: "Project Leader", start: 1, duration: 1, color: "#888" },
  { name: "Project Objectives", start: 2, duration: 3, color: "#0070c0" },
  { name: "Key Milestones", start: 4, duration: 1, color: "#f79646" },
  { name: "Functional Group Support", start: 4, duration: 1, color: "#00b050" },
  { name: "Reporting Relationships", start: 5, duration: 1, color: "#00b050" },
  { name: "Project Organization", start: 5, duration: 1, color: "#00b050" },
  { name: "Statement of Work", start: 6, duration: 5, color: "#888" },
  { name: "Project Budget", start: 11, duration: 2, color: "#0070c0" },
  { name: "Project Team", start: 11, duration: 2, color: "#0070c0" },
  { name: "Project Monitoring", start: 13, duration: 1, color: "#f79646" },
  { name: "Executive Approval", start: 14, duration: 1, color: "#888" }
];

const maxWeek = Math.max(...tasks.map(t => t.start + t.duration));
const unit = 30; // px per week

const chart = document.getElementById("chart");

// Axis
const axis = document.createElement("div");
axis.className = "axis";
for (let w = 1; w <= maxWeek; w++) {
  const tick = document.createElement("div");
  tick.className = "tick";
  tick.textContent = w;
  axis.appendChild(tick);
}
chart.appendChild(axis);

// Rows
tasks.forEach(t => {
  const row = document.createElement("div");
  row.className = "row";

  const label = document.createElement("div");
  label.className = "label";
  label.textContent = t.name;
  row.appendChild(label);

  const bar = document.createElement("div");
  bar.className = "bar";
  bar.style.background = t.color;
  bar.style.marginLeft = (t.start - 1) * unit + "px";
  bar.style.width = t.duration * unit + "px";

  row.appendChild(bar);
  chart.appendChild(row);
});
</script>

</body>
</html>
